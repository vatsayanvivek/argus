{
  "framework": "pci-dss-4",
  "display_name": "PCI DSS 4.0",
  "version": "4.0 (March 2022)",
  "authority": "Payment Card Industry Security Standards Council",
  "scope_note": "Maps ARGUS rules to PCI DSS 4.0 requirements relevant to the cardholder data environment (CDE) hosted in Microsoft Azure. Requirements 9 (physical) and 12 (policy) are out of scope for automated infrastructure checks.",
  "controls": {
    "1.2": {
      "title": "Network security controls configured and maintained",
      "description": "Network security controls (NSCs) are configured to restrict all traffic not specifically authorised; default-deny; reviewed at least every six months."
    },
    "1.3": {
      "title": "Network access to and from CDE is restricted",
      "description": "Inbound/outbound traffic to the CDE is restricted to what is necessary."
    },
    "1.4": {
      "title": "Network connections between trusted and untrusted networks are controlled",
      "description": "Perimeter NSCs between the CDE and untrusted networks (including the public internet) are implemented."
    },
    "2.2": {
      "title": "System components configured and managed securely",
      "description": "System components are configured using industry-accepted hardening standards and managed to prevent deviation."
    },
    "2.3": {
      "title": "Wireless environments configured securely",
      "description": "Wireless access points used for or that could impact the CDE are configured and managed in accordance with vendor recommendations."
    },
    "3.5": {
      "title": "Primary account number is secured wherever stored",
      "description": "PAN is protected with strong cryptography when stored."
    },
    "3.6": {
      "title": "Cryptographic keys used to protect stored account data are secured",
      "description": "Key management procedures restrict access, periodic rotation, and protect key-encrypting keys."
    },
    "4.2": {
      "title": "PAN is protected with strong cryptography during transmission",
      "description": "Strong cryptography and security protocols are used to safeguard PAN during transmission over open, public networks."
    },
    "6.3": {
      "title": "Security vulnerabilities identified and addressed",
      "description": "Vulnerabilities to system components are identified, ranked, and addressed."
    },
    "6.4": {
      "title": "Public-facing web applications protected against attacks",
      "description": "Public-facing web applications are protected via a WAF or equivalent, and checked for vulnerabilities continuously."
    },
    "7.2": {
      "title": "Access to system components and data restricted based on need-to-know",
      "description": "Access is assigned based on job classification and function; all access reviewed at least every six months."
    },
    "7.3": {
      "title": "Access to system components and data managed via an access-control system",
      "description": "An access-control system is in place that covers all components, default-deny, and assigns privileges based on individual role."
    },
    "8.2": {
      "title": "User identification and related accounts for users and administrators strictly managed throughout account lifecycle",
      "description": "Unique user IDs; revocation of access upon termination; inactive accounts removed; vendor accounts enabled only when required."
    },
    "8.3": {
      "title": "Strong authentication for users and administrators established and managed",
      "description": "Strong authentication is used; passwords meet minimum requirements; MFA required for non-console administrative access and all remote access into the CDE."
    },
    "8.4": {
      "title": "Multi-factor authentication for access into the CDE",
      "description": "MFA is implemented for all non-console access into the CDE and all remote access."
    },
    "8.5": {
      "title": "Multi-factor authentication systems configured to prevent misuse",
      "description": "MFA systems resistant to replay; cannot be bypassed by any administrator; at least two different factor types."
    },
    "8.6": {
      "title": "Accounts used by systems or applications managed",
      "description": "Interactive logins with application/system accounts are prevented or justified; passwords changed when personnel change roles."
    },
    "10.2": {
      "title": "Audit logs record details about users and actions affecting the CDE",
      "description": "Audit logs are enabled and active for all system components; record user identification, type of event, timestamp, success/failure, origination, affected data/resource."
    },
    "10.3": {
      "title": "Audit logs protected from destruction and unauthorized modifications",
      "description": "Logs are protected to prevent modification/deletion; file-integrity monitoring or change-detection used on log files."
    },
    "10.4": {
      "title": "Audit logs reviewed to identify anomalies or suspicious activity",
      "description": "Logs are reviewed at least daily; alerting in place for security-relevant events."
    },
    "10.5": {
      "title": "Audit log history retained and available for analysis",
      "description": "At least 12 months of audit log history retained, of which at least 3 months are immediately available for analysis."
    },
    "11.4": {
      "title": "External and internal penetration testing regularly performed",
      "description": "External penetration testing at least annually and after any significant change; internal penetration testing at the same cadence."
    },
    "11.5": {
      "title": "Network intrusions and unexpected file changes are detected and responded to",
      "description": "Intrusion-detection/prevention techniques used at the perimeter of the CDE and at critical points in the CDE."
    }
  },
