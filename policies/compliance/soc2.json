{
  "framework": "soc2",
  "display_name": "SOC 2 (AICPA Trust Services Criteria)",
  "version": "TSP 100 (2017, revised 2022)",
  "authority": "American Institute of Certified Public Accountants",
  "scope_note": "Maps ARGUS rules to SOC 2 Common Criteria and applicable category criteria (Security, Availability, Confidentiality). Criteria C1 and A1 are included where relevant; PI (Processing Integrity) and P (Privacy) are out of scope for cloud-infrastructure posture checks.",
  "controls": {
    "CC6.1": {
      "title": "Logical and Physical Access Controls",
      "description": "The entity implements logical access security software, infrastructure, and architectures over protected information assets to protect them from security events."
    },
    "CC6.2": {
      "title": "Access Provisioning",
      "description": "Prior to issuing system credentials and granting system access, the entity registers and authorizes new internal and external users."
    },
    "CC6.3": {
      "title": "Access Role Authorization",
      "description": "The entity authorizes, modifies, or removes access to data, software, functions, and other protected information assets based on roles, responsibilities, or the system design and changes, giving consideration to the concepts of least privilege and segregation of duties."
    },
    "CC6.6": {
      "title": "Boundary Protection",
      "description": "The entity implements logical access security measures to protect against threats from sources outside its system boundaries."
    },
    "CC6.7": {
      "title": "Data-in-Transit Protection",
      "description": "The entity restricts the transmission, movement, and removal of information to authorized internal and external users and processes, and protects it during transmission."
    },
    "CC6.8": {
      "title": "Malicious Software Prevention",
      "description": "The entity implements controls to prevent or detect and act upon the introduction of unauthorized or malicious software."
    },
    "CC7.1": {
      "title": "Vulnerability Detection",
      "description": "The entity uses detection and monitoring procedures to identify changes to configurations that may introduce new vulnerabilities and susceptibilities to security events."
    },
    "CC7.2": {
      "title": "System Monitoring",
      "description": "The entity monitors system components and the operation of controls for anomalies that are indicative of malicious acts, natural disasters, and errors."
    },
    "CC7.3": {
      "title": "Security Event Evaluation",
      "description": "The entity evaluates security events to determine whether they could or have resulted in a failure to meet its objectives and, if so, takes actions to prevent or address such failures."
    },
    "CC7.4": {
      "title": "Security Incident Response",
      "description": "The entity responds to identified security incidents by executing a defined incident-response program."
    },
    "CC8.1": {
      "title": "Change Management",
      "description": "The entity authorizes, designs, develops or acquires, configures, documents, tests, approves, and implements changes to infrastructure, data, software, and procedures to meet its objectives."
    },
    "A1.2": {
      "title": "Availability - Environmental Protections & Backups",
      "description": "The entity authorizes, designs, develops or acquires, implements, operates, approves, maintains, and monitors environmental protections, software, data back-up processes, and recovery infrastructure to meet its objectives."
    },
    "C1.1": {
      "title": "Confidential Information Identification and Classification",
      "description": "The entity identifies and maintains confidential information to meet the entity's objectives related to confidentiality."
    },
    "C1.2": {
      "title": "Confidential Information Disposal",
      "description": "The entity disposes of confidential information to meet the entity's objectives related to confidentiality."
    }
  },
