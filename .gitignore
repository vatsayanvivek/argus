# ===========================================================================
# Compiled binary (built by `make build` or CI)
# ===========================================================================
/argus
/argus.exe
/dist/
/scripts/dist/

# ===========================================================================
# Scan / test outputs (CONTAIN REAL AZURE DATA — never commit)
# ===========================================================================
# Cover every output-dir variant: `argus-output`, `argus-output-*`,
# `argus-output-anything-v12b`, etc. Also test-scoped dirs we use while
# validating features against live tenants.
argus-output*/
argus-test*/
argus-final*/
argus-evidence*/
argus-evidence-*.zip
argus-scan-*/
# Personal / customer / environment-scoped test output dirs. Use generic
# names like ./local-scan/ or ./private/ for integration-test runs so no
# tenant or customer identifier appears in any tracked filename.
local-scan*/
private*/
*-prod-*-output/
*-customer-*/

# Generated report files (only inside output dirs above; the canonical
# templates/report.html is the SOURCE for the HTML reporter and IS tracked)
argus_*.html
argus_*.json
argus_*.sarif

# ===========================================================================
# Suppression file (every customer's is private to their environment)
# ===========================================================================
.argusignore

# ===========================================================================
# Scan history (contains tenant identifiers)
# ===========================================================================
.argus/

# ===========================================================================
# Coverage / profiling
# ===========================================================================
coverage.out
coverage.html
*.prof

# ===========================================================================
# Editor / IDE / OS noise
# ===========================================================================
.vscode/
.idea/
.claude/
*.swp
*.swo
.DS_Store
Thumbs.db

# ===========================================================================
# Go test artifacts
# ===========================================================================
*.test
*.out

# ===========================================================================
# Embed staging dirs — regenerated by `make embed-prep` from the canonical
# `policies/`, `data/`, and `templates/` directories at repo root.
# These mirrors must NOT be tracked (they would create duplicate sources of
# truth).
# ===========================================================================
internal/engine/policies/
internal/benchmark/data/
internal/reporter/templates/
internal/drift/builtin_roles.json
